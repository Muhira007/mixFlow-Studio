# ⚠️ FILE SENSITIF - JANGAN COMMIT ⚠️
# .env, uploads/*, outputs/*, dan file sensitif lainnya
# Lihat .gitignore untuk daftar lengkap

# Environment variables (API Keys)
.env
.env.local
.env.*.local

# Folder temporary (bisa berisi file user)
uploads/*
!uploads/.gitkeep
outputs/*
!outputs/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep
backend/outputs/*
!backend/outputs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
*.pyc

# Streamlit
.streamlit/secrets.toml

# IDE
.vscode/
.idea/

# Database & user data (jangan commit!)
backend/data/

# Logs
logs/

# Build reference (local only)
build2026.md

# Next.js build
.next/

# OS
.DS_Store
Thumbs.db
