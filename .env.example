# ============================================
# mixFlow - Environment Variables Template
# Copy file ini ke .env lalu isi dengan key asli
# ============================================
# ⚠️  JANGAN COMMIT .env KE GITHUB!
# ⚠️  .env sudah terdaftar di .gitignore

# Eleven Labs (Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_default_voice_id_here

# DeepSeek AI (Script Generator)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Gemini (Script Generator)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (Script Generator)
OPENAI_API_KEY=your_openai_api_key_here

# Context7 MCP (Library Documentation Lookup)
CONTEXT7_API_KEY=api_key_here

# Optional: Minimum durasi per footage (detik)
MIN_KEEP_DURATION=3
